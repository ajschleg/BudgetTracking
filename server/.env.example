PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox
PORT=8080

# Optional: Publicly reachable HTTPS URL for Plaid webhooks.
# For local dev, use ngrok: `ngrok http 8080` and set this to the
# forwarded URL, e.g. https://abc123.ngrok.io/webhook
# Leave unset to disable webhooks (manual sync still works).
# PLAID_WEBHOOK_URL=https://your-domain.com/webhook
