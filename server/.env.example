PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_sandbox_secret
PLAID_ENV=sandbox
PORT=8080

# Optional: Publicly reachable HTTPS URL for Plaid webhooks.
# For local dev, use ngrok: `ngrok http 8080` and set this to the
# forwarded URL, e.g. https://abc123.ngrok.io/webhook
# Leave unset to disable webhooks (manual sync still works).
# PLAID_WEBHOOK_URL=https://your-domain.com/webhook

# Required when exposing the server publicly (e.g. via ngrok).
# Shared secret between the macOS app and the server; the app sends it
# as X-App-Token on every /api/* request. Generate a long random value:
#   openssl rand -hex 32
# Leave unset in local-only dev to disable auth (a warning is logged).
# APP_AUTH_TOKEN=

# Encrypts Plaid access tokens at rest in plaid.db using AES-256-GCM.
# Generate a 32-byte hex key:
#   openssl rand -hex 32
# If unset, the server auto-generates and persists .encryption-key
# (chmod 600) on first boot. BACK THIS UP — losing it makes encrypted
# tokens unrecoverable and you will need to re-link every bank.
# ENCRYPTION_KEY=

# Optional manual override for Plaid's OAuth redirect URI. If unset:
#   - sandbox defaults to http://localhost:8080/oauth.html
#   - production/development defaults to
#     https://ajschleg.github.io/BudgetTracking/oauth.html
# Plaid requires HTTPS in production — set this only if you have your
# own registered HTTPS domain.
# PLAID_REDIRECT_URI=
